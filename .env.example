# ══════════════════════════════════════════════════════════════════════════════
# Hermes — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values as needed.
# All variables have sensible defaults; only LLM credentials require attention.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM (one of the three options below is required) ──────────────────────────
#
# Option A — Anthropic Claude (best quality; requires API key)
ANTHROPIC_API_KEY=

# Option B — OpenAI (requires API key)
OPENAI_API_KEY=

# Option C — Local Ollama (free; no key needed; CPU/GPU)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5-coder:7b

# ── Infrastructure ─────────────────────────────────────────────────────────────
# When running locally (outside Docker), keep these pointing to localhost.
# docker-compose.yml overrides them to use container service names.
POSTGRES_DSN=postgresql://scraper:scraper@localhost:5432/scraperdb
REDIS_URL=redis://localhost:6379/0

# ── Scraper behaviour ──────────────────────────────────────────────────────────
SCRAPE_LIMIT=100                      # max articles per run
SCRAPER_MAX_PAGES=5                   # max listing pages per section
SCRAPER_CONCURRENCY=3                 # parallel article fetches
SCRAPER_DELAY_MIN=1.5                 # politeness delay between requests (seconds)
SCRAPER_DELAY_MAX=3.5
SCRAPER_MAX_SECTIONS=50               # max sections/categories to discover
SCRAPER_SCROLL_MAX=20                 # infinite-scroll iterations before stopping
SCRAPER_SCROLL_WAIT_MS=1500           # ms to wait between scroll steps

# ── Browser ────────────────────────────────────────────────────────────────────
HEADLESS=True
BROWSER_TIMEOUT=45000                 # Playwright navigation timeout (ms)
USE_STEALTH=True                      # apply playwright-stealth patches
NAVIGATION_STRATEGY=domcontentloaded  # domcontentloaded | networkidle
IMPERSONATE_BROWSER=chrome120         # curl-cffi TLS profile

# ── Selector discovery ─────────────────────────────────────────────────────────
RETRY_DEEP_ANALYSIS_WEBSITE_SELECTORS=3  # LLM retries on selector validation failure
LLM_SELECTOR_CACHE_TTL=30               # days before PostgreSQL selector cache expires

# ── Content quality ────────────────────────────────────────────────────────────
MIN_TITLE_LENGTH=20                   # articles with shorter titles are discarded

# ── Enrichments (all off by default for performance) ──────────────────────────
CAPTURE_SCREENSHOT=False              # save full-page JPEG/PNG per article
SCREENSHOT_TYPE=jpeg                  # jpeg | png
EXTRACT_EMAILS=False                  # extract email addresses from article text
EXTRACT_HASHTAGS=False                # extract hashtags from article text

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                    # console (human) | json (structured)
